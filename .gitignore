```gitignore
############################################
# OS
############################################

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini


############################################
# IntelliJ IDEA
############################################

.idea/
*.iml
out/


############################################
# VS Code
############################################

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json


############################################
# Java
############################################

*.class
*.log
*.ctxt

hs_err_pid*
replay_pid*


############################################
# Maven
############################################

target/

.mvn/wrapper/maven-wrapper.jar


############################################
# Gradle（预留）
############################################

.gradle/
build/


############################################
# Node.js
############################################

node_modules/

npm-debug.log*

pnpm-debug.log*

yarn-debug.log*

yarn-error.log*


############################################
# Frontend Build
############################################

dist/

coverage/

.cache/

.temp/

.eslintcache


############################################
# Environment
############################################

.env.local

.env.development.local

.env.test.local

.env.production.local


############################################
# Logs
############################################

logs/

*.log


############################################
# Runtime Files
############################################

*.pid

*.seed

*.pid.lock


############################################
# Package Manager
############################################

.pnpm-store/


############################################
# Temporary Files
############################################

tmp/

temp/

*.tmp

*.swp

*.swo

*~


############################################
# Database
############################################

*.db

*.sqlite

*.sqlite3


############################################
# Upload Files
############################################

uploads/

storage/

files/


############################################
# Claude Code
############################################

#.claude/

.claude/settings.local.json

.claude-cache/

.claude-history/


############################################
# Local Config
############################################

local.properties

application-local.yml

application-dev.yml

application-secret.yml


############################################
# Archives
############################################

*.zip

*.tar

*.gz

*.rar


############################################
# Generated Files
############################################

generated/

generated-sources/


############################################
# Misc
############################################

*.bak

*.old

*.orig
```
