<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.personalhub.system.mapper.NotificationMapper">

    <!-- 标记所有通知为已读 -->
    <update id="markAllAsReadXml">
        UPDATE sys_notification
        SET is_read = 1
        WHERE user_id = #{userId}
          AND is_read = 0
    </update>

    <!-- 清空用户通知（软清除，避免下次 check 再次生成） -->
    <update id="clearAllXml">
        UPDATE sys_notification
        SET is_dismissed = 1,
            is_read      = 1
        WHERE user_id = #{userId}
          AND is_dismissed = 0
    </update>

    <!-- 查询所有用户ID -->
    <select id="selectAllUserIds" resultType="long">
        SELECT DISTINCT id
        FROM sys_user
    </select>

</mapper>
