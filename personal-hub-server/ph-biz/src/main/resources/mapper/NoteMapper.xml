<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.personalhub.knowledge.mapper.NoteMapper">

    <!-- 分页查询笔记（含分类/标签子查询） -->
    <select id="selectNotePage" resultType="com.personalhub.knowledge.entity.Note">
        SELECT n.* FROM note_note n
        <where>
            n.user_id = #{userId}
            AND n.is_deleted = <choose>
                <when test="query.isDeleted != null and query.isDeleted">1</when>
                <otherwise>0</otherwise>
            </choose>
            <if test="query.keyword != null and query.keyword != ''">
                AND n.title LIKE CONCAT('%', #{query.keyword}, '%')
            </if>
            <if test="query.isFavorite != null and query.isFavorite">
                AND n.is_favorite = 1
            </if>
            <if test="query.categoryId != null">
                AND EXISTS (SELECT 1 FROM note_category_rel WHERE note_id = n.id AND category_id = #{query.categoryId})
            </if>
            <if test="query.tagId != null">
                AND EXISTS (SELECT 1 FROM tag_rel WHERE entity_id = n.id AND entity_type = 'note' AND tag_id = #{query.tagId})
            </if>
        </where>
        ORDER BY n.updated_at DESC
    </select>

    <!-- 分页查询回收站（按删除时间倒序） -->
    <select id="selectRecyclePage" resultType="com.personalhub.knowledge.entity.Note">
        SELECT n.* FROM note_note n
        <where>
            n.user_id = #{userId} AND n.is_deleted = 1
            <if test="query.keyword != null and query.keyword != ''">
                AND n.title LIKE CONCAT('%', #{query.keyword}, '%')
            </if>
        </where>
        ORDER BY n.deleted_at DESC
    </select>

    <!-- 查询笔记的分类列表 -->
    <select id="selectCategoriesByNoteId" resultType="map">
        SELECT c.id, c.name FROM category c
        INNER JOIN note_category_rel r ON c.id = r.category_id
        WHERE r.note_id = #{noteId} AND c.type = 'note'
    </select>

    <!-- 批量查询笔记分类 -->
    <select id="selectCategoriesByNoteIds" resultType="map">
        SELECT r.note_id AS noteId, c.id, c.name FROM category c
        INNER JOIN note_category_rel r ON c.id = r.category_id
        WHERE c.type = 'note'
        <if test="noteIds != null and noteIds.size() &gt; 0">
            AND r.note_id IN
            <foreach collection="noteIds" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="noteIds == null or noteIds.size() == 0">
            AND 1 = 0
        </if>
    </select>

    <!-- 按笔记删除分类关联 -->
    <delete id="deleteCategoryRelsByNoteId">
        DELETE FROM note_category_rel WHERE note_id = #{noteId}
    </delete>

    <!-- 批量插入笔记-分类关联 -->
    <insert id="insertCategoryRels">
        INSERT INTO note_category_rel (note_id, category_id) VALUES
        <foreach collection="categoryIds" item="cid" separator=",">
            (#{noteId}, #{cid})
        </foreach>
    </insert>

</mapper>
