# 复制到 VM：sudo mkdir -p /opt/personal-hub && sudo cp deploy/.env.example /opt/personal-hub/.env
# 然后编辑：sudo vim /opt/personal-hub/.env（或 vi / WinSCP / VS Code Remote）
# 切勿将真实 .env 提交到 Git

# MySQL（容器服务名固定为 mysql，应用内 HOST 一般勿改）
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=personal_hub
MYSQL_USER=al_user
MYSQL_PASSWORD=change-me-mysql-password
MYSQL_HOST=mysql
MYSQL_PORT=3306
# 宿主机映射端口（本机/IDE 直连）；冲突可改 13306。仅本机访问可改为 127.0.0.1:3306（需改 compose 写法，见 DEPLOYMENT）
MYSQL_PUBLISH=3306

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DATABASE=0
REDIS_PUBLISH=6379

# JWT（请使用足够长的随机字符串）
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_EXPIRATION=86400000

# 文件存储（容器内路径；宿主机通过 bind mount 映射）
STORAGE_LOCATION=/data/personal-hub/uploads
STORAGE_MAX_SIZE=104857600

# 应用日志目录（按天滚动，最多保留 30 天）
LOG_PATH=/data/personal-hub/logs

# 对外端口（宿主机）
HTTP_PORT=80

# 构建期一般不用代理（前端 npmmirror / 后端阿里云 Maven）
# 若仍需要给构建容器走 Clash，须 Allow LAN，且勿填 127.0.0.1：
# BUILD_HTTP_PROXY=http://host.docker.internal:7897
